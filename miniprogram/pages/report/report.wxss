.report-page {
  padding: 32rpx;
  background: #f0f2f0;
  min-height: 100vh;
}

.report-loading, .report-empty {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.report-header {
  text-align: center;
  padding: 40rpx 0 32rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #5B8C5A;
  margin-bottom: 16rpx;
}

.section-body {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-top: 12rpx;
}

.constitution-badge {
  display: inline-block;
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, #8B6914, #6B4914);
  color: #fff;
  border-radius: 32rpx;
  font-size: 24rpx;
}

.actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(90deg, #5B8C5A, #7CB342);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}

.btn-back {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.disclaimer {
  margin-top: 32rpx;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.disclaimer text {
  font-size: 22rpx;
  color: #999;
}
