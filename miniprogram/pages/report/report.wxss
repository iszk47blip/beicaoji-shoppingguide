.report-page {
  padding: 32rpx;
  background: #f9f9f9;
}

.report-header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.section {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #5B8C5A;
  margin-bottom: 16rpx;
}

.section-body {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.product-card {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.product-card:last-child {
  border-bottom: none;
}

.product-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.product-ingredients {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.product-price {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #e6a23c;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #5B8C5A;
  color: white;
  border-radius: 44rpx;
  font-size: 32rpx;
  margin-top: 32rpx;
}

.disclaimer {
  margin-top: 32rpx;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.disclaimer text {
  font-size: 22rpx;
  color: #999;
}
