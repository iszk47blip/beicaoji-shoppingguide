.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f2f0;
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: #5B8C5A;
  color: #fff;
}

.header-title {
  font-size: 30rpx;
  font-weight: 600;
}

.header-orders {
  font-size: 24rpx;
  opacity: 0;
  transition: opacity 0.2s;
}

.header-orders.visible {
  opacity: 1;
}

.message-list {
  flex: 1;
  padding: 20rpx 24rpx;
}

.message-list.has-cart {
  padding-bottom: 100rpx;
}

.msg-row {
  display: flex;
  margin-bottom: 20rpx;
  animation: msgIn 0.25s ease-out;
}

.msg-row.user {
  justify-content: flex-end;
}

.msg-row.bot {
  justify-content: flex-start;
}

.msg-row.system {
  justify-content: center;
}

.msg-block {
  max-width: 82%;
  display: flex;
  flex-direction: column;
}

.msg-row.user .msg-block {
  max-width: 75%;
}

.bubble {
  padding: 20rpx 28rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
}

.msg-row.user .bubble {
  background-color: #5B8C5A;
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.msg-row.bot .bubble {
  background-color: #fff;
  color: #333;
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.msg-row.system .bubble {
  background-color: #e8f5e9;
  color: #5B8C5A;
  font-size: 24rpx;
  text-align: center;
}

/* Typing dots */
.typing {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx 36rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #999;
  animation: bounce 1.2s infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-12rpx); }
}

@keyframes msgIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Quick replies */
.quick-replies {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  background: #f0f2f0;
}

.quick-btn {
  padding: 14rpx 28rpx;
  background: #fff;
  color: #5B8C5A;
  border: 1rpx solid #5B8C5A;
  border-radius: 36rpx;
  font-size: 26rpx;
}

.quick-btn:active {
  background: #5B8C5A;
  color: #fff;
}

/* Input bar */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  border: 1rpx solid #ddd;
  border-radius: 36rpx;
  font-size: 28rpx;
  background: #f5f5f5;
}

.send-btn {
  margin-left: 16rpx;
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  background: #5B8C5A;
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Recommendation */
.rec-container {
  margin-top: 8rpx;
}

.constitution-badge {
  display: inline-block;
  padding: 10rpx 28rpx;
  background: linear-gradient(135deg, #8B6914, #6B4914);
  color: #fff;
  border-radius: 32rpx;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.report-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(90deg, #5B8C5A, #7CB342);
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  margin-top: 16rpx;
}

/* Catalog */
.catalog-container {
  margin-top: 8rpx;
}

.catalog-group {
  margin-bottom: 24rpx;
}

.catalog-header {
  padding: 16rpx 0 8rpx;
}

.catalog-ctype {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, #8B6914, #6B4914);
  color: #fff;
  border-radius: 32rpx;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.catalog-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}
