.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f2f0;
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: #5B8C5A;
  color: #fff;
}

.header-title {
  font-size: 30rpx;
  font-weight: 600;
}

.header-orders {
  font-size: 24rpx;
  opacity: 0;
  transition: opacity 0.2s;
}

.header-orders.visible {
  opacity: 1;
}

.message-list {
  flex: 1;
  padding: 20rpx 24rpx 200rpx;
}

.message-list.has-cart {
  padding-bottom: 300rpx;
}

/* Fixed bottom bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background: #f0f2f0;
}

.msg-row {
  display: flex;
  margin-bottom: 20rpx;
  animation: msgIn 0.25s ease-out;
}

.msg-row.user {
  justify-content: flex-end;
}

.msg-row.bot {
  justify-content: flex-start;
}

.msg-row.system {
  justify-content: center;
}

.msg-block {
  max-width: 82%;
  display: flex;
  flex-direction: column;
}

.msg-row.user .msg-block {
  max-width: 75%;
}

.bubble {
  padding: 20rpx 28rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
}

.msg-row.user .bubble {
  background-color: #5B8C5A;
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.msg-row.bot .bubble {
  background-color: #fff;
  color: #333;
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.msg-row.system .bubble {
  background-color: #e8f5e9;
  color: #5B8C5A;
  font-size: 24rpx;
  text-align: center;
}

/* Typing dots */
.typing {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx 36rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #999;
  animation: bounce 1.2s infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-12rpx); }
}

@keyframes msgIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Quick replies */
.quick-replies {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 8rpx 24rpx;
}

.quick-btn {
  padding: 14rpx 28rpx;
  background: #fff;
  color: #5B8C5A;
  border: 1rpx solid #5B8C5A;
  border-radius: 36rpx;
  font-size: 26rpx;
}

.quick-btn:active {
  background: #5B8C5A;
  color: #fff;
}

/* Input bar */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  border: 1rpx solid #ddd;
  border-radius: 36rpx;
  font-size: 28rpx;
  background: #f5f5f5;
}

.send-btn {
  margin-left: 16rpx;
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  background: #5B8C5A;
  color: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Spacing below LLM text before prescription card */
.rx-text {
  margin-bottom: 8rpx;
}

/* Prescription card — Chinese medicine aesthetic */
.prescription-card {
  margin-top: 24rpx;
  background: linear-gradient(175deg, #fdf8f0 0%, #faf3e6 40%, #f7edd8 100%);
  border: 2rpx solid #d4c5a0;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 105, 20, 0.12), inset 0 0 0 8rpx #fefbf6;
}

.rx-inner {
  padding: 24rpx 20rpx 20rpx;
  border: 1rpx solid #e8dcc8;
  border-radius: 4rpx;
  margin: 8rpx;
}

.rx-seal-row {
  text-align: center;
  margin-bottom: 8rpx;
}

.rx-seal {
  display: inline-block;
  padding: 12rpx 32rpx;
  background: #8B2500;
  color: #f5e6d0;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border: 3rpx double #c4956a;
  box-shadow: 0 2rpx 8rpx rgba(139, 37, 0, 0.25);
}

.rx-subtitle {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #b5a080;
  letter-spacing: 6rpx;
  margin-top: 4rpx;
}

.rx-desc {
  display: block;
  font-size: 24rpx;
  color: #8b7355;
  line-height: 1.7;
  text-align: center;
  margin-top: 12rpx;
  padding: 0 8rpx;
}

.rx-ornament {
  text-align: center;
  font-size: 32rpx;
  color: #c4a882;
  margin: 16rpx 0 2rpx;
  letter-spacing: 12rpx;
}

.rx-products-title {
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #6b4f30;
  letter-spacing: 6rpx;
  margin-bottom: 8rpx;
}

.rx-report-btn {
  width: 100%;
  height: 68rpx;
  line-height: 68rpx;
  background: linear-gradient(135deg, #8B4513, #6B3410);
  color: #faf3e6;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  margin-top: 16rpx;
  border: none;
}

/* Catalog */
.catalog-container {
  margin-top: 8rpx;
}

.catalog-group {
  margin-bottom: 24rpx;
}

.catalog-header {
  padding: 16rpx 0 8rpx;
}

.catalog-ctype {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, #8B6914, #6B4914);
  color: #fff;
  border-radius: 32rpx;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.catalog-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}
