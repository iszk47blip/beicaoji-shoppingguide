<view class="chat-container">
  <view class="chat-header">
    <text class="header-title">焙草集 AI 健康顾问</text>
    <text class="header-orders {{hasOrders ? 'visible' : ''}}" bindtap="onShowOrders">我的订单</text>
  </view>
  <scroll-view class="message-list {{cartCount > 0 ? 'has-cart' : ''}}" scroll-y scroll-into-view="msg-{{messages.length - 1}}" scroll-with-animation>
    <block wx:for="{{messages}}" wx:key="index">
      <view id="msg-{{index}}" class="msg-row {{item.role}}">
        <view class="msg-block" wx:if="{{item.type === 'text'}}">
          <view class="bubble">{{item.content}}</view>
        </view>

        <view class="msg-block" wx:if="{{item.type === 'recommendation'}}">
          <view class="bubble">{{item.content}}</view>
          <view class="rec-container">
            <view class="constitution-badge">{{item.constitution.constitution_type}}</view>
            <product-card wx:for="{{item.bundle}}" wx:key="sku_id" product="{{item}}" quantity="{{item.quantity || 0}}" bind:quantitychange="onProductQuantityChange"/>
            <button class="report-btn" bindtap="onViewReport">查看完整调理报告</button>
          </view>
        </view>

        <view class="msg-block" wx:if="{{item.type === 'catalog'}}">
          <view class="bubble" wx:if="{{item.content}}">{{item.content}}</view>
          <view class="catalog-container">
            <block wx:for="{{item.categories}}" wx:for-item="cat" wx:key="constitution">
              <view class="catalog-group">
                <view class="catalog-header">
                  <text class="catalog-ctype">{{cat.constitution}}</text>
                  <text class="catalog-desc">{{cat.description}}</text>
                </view>
                <product-card wx:for="{{cat.products}}" wx:for-item="prod" wx:key="sku_id" product="{{prod}}" quantity="{{prod.quantity || 0}}" bind:quantitychange="onProductQuantityChange"/>
              </view>
            </block>
          </view>
        </view>
      </view>
    </block>

    <view wx:if="{{loading}}" class="msg-row bot" id="loading-msg">
      <view class="bubble typing">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
    </view>
  </scroll-view>

  <view class="quick-replies" wx:if="{{quickReplies.length > 0}}">
    <view class="quick-btn" wx:for="{{quickReplies}}" wx:key="index" bindtap="onQuickReply" data-text="{{item}}">{{item}}</view>
  </view>

  <cart-bar count="{{cartCount}}" total="{{cartTotal}}" bind:tap="onCartBarTap"/>

  <view class="input-bar">
    <input class="input" placeholder="输入你的情况..."
           value="{{inputText}}" bindinput="onInput" confirm-type="send"
           bindconfirm="onSend"/>
    <button class="send-btn" bindtap="onSend">发送</button>
  </view>
</view>

<cart-panel show="{{cartPanelShow}}" items="{{cartItems}}" total="{{cartTotal}}"
  bind:close="onCartPanelClose" bind:qtychange="onCartQtyChange"
  bind:remove="onCartRemove" bind:clear="onCartClear"
  bind:copy="onCartCopy" bind:checkout="onCartCheckout"/>

<order-modal show="{{orderShow}}" items="{{cartItems}}" total="{{cartTotal}}" count="{{cartCount}}"
  orderNo="{{orderNo}}" orderTime="{{orderTime}}"
  bind:close="onOrderClose" bind:confirm="onOrderConfirm"/>
