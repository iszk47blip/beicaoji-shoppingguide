.orders-page {
  min-height: 100vh;
  background: #f0f2f0;
  padding: 24rpx;
}

.orders-header {
  padding: 20rpx 0 32rpx;
}

.orders-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.order-card-hd {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-card-no {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.order-card-time {
  font-size: 24rpx;
  color: #999;
}

.order-card-items {
  margin-bottom: 12rpx;
}

.order-card-item {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.order-card-ft {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  font-weight: 600;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-card-total {
  color: #e6a23c;
}

.orders-empty {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-icon {
  display: block;
  font-size: 72rpx;
  margin-bottom: 24rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 12rpx;
}
