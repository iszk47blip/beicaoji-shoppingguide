<view class="order-overlay {{show ? 'show' : ''}}" bindtap="onClose">
  <view class="order-modal {{show ? 'show' : ''}}" catchtap="noop">
    <view class="order-header">
      <view class="order-check">✓</view>
      <text class="order-title">订单确认</text>
    </view>
    <view class="order-no">订单号：{{orderNo}}</view>
    <view class="order-time">{{orderTime}}</view>

    <view class="order-section">
      <text class="order-section-title">选购商品</text>
      <view class="order-item" wx:for="{{items}}" wx:key="sku_id">
        <text class="order-item-name">{{item.name}}</text>
        <text class="order-item-meta">x{{item.quantity}}</text>
        <text class="order-item-price">¥{{(item.price * item.quantity).toFixed(1)}}</text>
      </view>
      <view class="order-total-row">
        <text>合计</text>
        <text class="order-total-price">¥{{total.toFixed(1)}}</text>
      </view>
    </view>

    <view class="order-section">
      <text class="order-section-title">取货方式</text>
      <text class="order-pickup">到店自取 · 请向店员出示此订单</text>
    </view>

    <view class="order-actions">
      <button class="btn-order-close" bindtap="onClose">继续选购</button>
      <button class="btn-order-confirm" bindtap="onConfirm">确认下单</button>
    </view>
  </view>
</view>
