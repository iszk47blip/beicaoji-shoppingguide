.order-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s;
}

.order-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.order-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 80vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.25s ease-out;
  padding: 32rpx;
  overflow-y: auto;
}

.order-modal.show {
  transform: translateY(0);
}

.order-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.order-check {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #5B8C5A;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.order-title {
  font-size: 36rpx;
  font-weight: 700;
}

.order-no, .order-time {
  font-size: 24rpx;
  color: #999;
  margin-left: 72rpx;
}

.order-section {
  margin-top: 28rpx;
}

.order-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.order-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-item-name {
  flex: 1;
  font-size: 28rpx;
}

.order-item-meta {
  font-size: 24rpx;
  color: #999;
}

.order-item-price {
  font-size: 26rpx;
  font-weight: 600;
}

.order-total-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  font-size: 32rpx;
  font-weight: 600;
}

.order-total-price {
  color: #e6a23c;
}

.order-pickup {
  font-size: 26rpx;
  color: #999;
}

.order-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
  padding-bottom: 20rpx;
}

.btn-order-close {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: #f5f5f5;
  color: #666;
  border: none;
  line-height: 80rpx;
}

.btn-order-confirm {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: linear-gradient(90deg, #5B8C5A, #7CB342);
  color: #fff;
  border: none;
  line-height: 80rpx;
}
