.rec-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin: 12rpx 0;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.card-emoji {
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.bg-biscuit { background: #fdf2e9; }
.bg-bread   { background: #fdedec; }
.bg-tea     { background: #e8f8f5; }
.bg-toy     { background: #f4ecf7; }

.card-body {
  flex: 1;
  min-width: 0;
}

.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.card-ingredients {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #e6a23c;
}

.card-actions {
  flex-shrink: 0;
  margin-left: auto;
}

.btn-buy-now {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #5B8C5A;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}
