.rec-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 16rpx;
  margin: 8rpx 0;
  background: rgba(255,255,255,0.7);
  border-radius: 12rpx;
  border: 1rpx solid #e8dcc8;
}

.card-emoji {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.bg-biscuit { background: #faf0e0; }
.bg-bread   { background: #fdf0ed; }
.bg-tea     { background: #eaf5ed; }
.bg-toy     { background: #f5eff8; }

.card-body {
  flex: 1;
  min-width: 0;
}

.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a3728;
  margin-bottom: 4rpx;
}

.card-ingredients {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #b87333;
}

.card-actions {
  flex-shrink: 0;
  margin-left: auto;
}
