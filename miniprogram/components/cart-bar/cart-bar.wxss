.cart-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 28rpx;
  background: #3d3226;
  color: #fff;
  border-radius: 48rpx;
  margin: 0 20rpx 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
  animation: slideUp 0.2s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); opacity: 0; }
  to   { transform: translateY(0); opacity: 1; }
}

.cart-icon {
  position: relative;
  font-size: 36rpx;
}

.cart-badge {
  position: absolute;
  top: -12rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  background: #e74c3c;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.cart-total {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
}

.cart-arrow {
  font-size: 40rpx;
  opacity: 0.6;
}
